# Environment Variables Template
# Copy this to .env and fill in your actual values
# NEVER commit .env with real secrets!

# DEBUG MODE
DEBUG_MODE=1
ENVIRONMENT=local

# DATABASE CONFIG VARIABLES
DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=
DB_NAME=stmargareth_db

# Email Configuration (Gmail - Google)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# API CONFIGURATION
VITE_API_BASE_URL=http://localhost/stmargareth/api

# SUPABASE CONFIGURATION
VITE_SUPABASE_URL=https://btflwhesaunzdqnpjcdi.supabase.co
VITE_SUPABASE_ANON_KEY=PLACEHOLDER_ADD_YOUR_ANON_KEY

# Google Drive API Credentials
# Get these from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=PLACEHOLDER_GET_FROM_GOOGLE_CLOUD_CONSOLE
GOOGLE_CLIENT_SECRET=PLACEHOLDER_GET_FROM_GOOGLE_CLOUD_CONSOLE

# Optional: Google Drive Folder ID for backups
# (Auto-created as "Pharmacy Backups" if not specified)
GOOGLE_DRIVE_BACKUP_FOLDER_ID=
